{
  "name": "local-addon-wp-sync",
  "productName": "WP Live Sync",
  "version": "1.2.0",
  "description": "Pull your self-hosted WordPress site into Local WP and push changes back to live.",
  "author": "Ramkumar R <info@blueburn.in>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/24gb-uk/local-addon-wp-sync.git"
  },
  "homepage": "https://github.com/24gb-uk/local-addon-wp-sync#readme",
  "bugs": {
    "url": "https://github.com/24gb-uk/local-addon-wp-sync/issues"
  },
  "engines": {
    "local-by-flywheel": ">=6.0.0"
  },
  "main": "lib/main/index.js",
  "renderer": "lib/renderer/renderer.js",
  "icon": "icon.svg",
  "keywords": [
    "local-addon",
    "wordpress",
    "sync",
    "deploy",
    "pull",
    "push"
  ],
  "scripts": {
    "build": "tsc && webpack --mode=production",
    "watch": "concurrently \"tsc --watch\" \"webpack --watch --mode=development\"",
    "postinstall": "yarn build"
  },
  "localAddon": {
    "name": "WP Live Sync",
    "description": "Pull and push full WordPress sites between Local and your live self-hosted server via REST API.",
    "icon": "icon.svg"
  },
  "dependencies": {
    "archiver": "^6.0.1",
    "axios": "^1.6.0",
    "decompress": "^4.2.1",
    "form-data": "^4.0.0",
    "node-stream-zip": "^1.15.0"
  },
  "devDependencies": {
    "@getflywheel/local": "^9.0.0 || ^10.0.0",
    "@getflywheel/local-components": "^17.0.0",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "@types/archiver": "^6.0.0",
    "@types/decompress": "^4.2.4",
    "@types/node": "^18.0.0",
    "@types/react": "^16.14.0",
    "@types/react-dom": "^16.9.0",
    "concurrently": "^8.0.0",
    "css-loader": "^6.8.0",
    "style-loader": "^3.3.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.0.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0"
  }
}
